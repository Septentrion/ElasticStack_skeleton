# =============================================================================
#  SciPulse — Variables d'environnement
#  Copier ce fichier en .env et adapter les valeurs si nécessaire
#  Usage : cp .env.example .env
# =============================================================================

# --- Elasticsearch ---
ES_HOST=http://localhost:9200

# --- PostgreSQL (dbt) ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=scipulse
PG_PASSWORD=scipulse
PG_DATABASE=scipulse

# --- MinIO (S3) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Airflow ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# --- HN Poller ---
HN_POLL_INTERVAL=60
HN_BATCH_SIZE=50
